PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/weather-intelligence?retryWrites=true&w=majority

# OpenWeatherMap — get free key at https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# WAQI (World Air Quality Index) — get free token at https://waqi.info/
WAQI_API_TOKEN=your_waqi_token_here

# FastAPI ML Service URL
ML_SERVICE_URL=http://localhost:8000

# Frontend origin (for CORS)
CORS_ORIGIN=http://localhost:5173
